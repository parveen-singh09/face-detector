---
import BaseLayout from "../layouts/BaseLayout.astro";
import ErrorState from "../components/ErrorState.astro";
import { useTranslations } from "../i18n/utils";

const p = useTranslations("en").pages.serverError;
---

<BaseLayout title={p.title} description={p.description} path="/500">
  <ErrorState code={p.code} title={p.heading} message={p.message} />
</BaseLayout>
