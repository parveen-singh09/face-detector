---
import BaseLayout from "../layouts/BaseLayout.astro";
import ErrorState from "../components/ErrorState.astro";
---

<BaseLayout
  title="Something went wrong (500) — AI Face Shape Analyzer"
  description="An unexpected error occurred. Try again or head back home to find your face shape in seconds."
  path="/500"
>
  <ErrorState
    code="500"
    title="Something went wrong on our end."
    message="An unexpected error stopped this page from loading. Try again in a moment, or head back home to find your face shape."
  />
</BaseLayout>
