---
/**
 * Localized homepage — /es/, /fr/, /ar/, … One static page per non-default
 * locale; English stays at the root (/).
 */
import HomePage from "../../components/pages/HomePage.astro";
import { NON_DEFAULT_LOCALES, type Locale } from "../../i18n/config";

export function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
---

<HomePage lang={lang} />
