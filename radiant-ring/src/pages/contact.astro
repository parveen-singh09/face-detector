---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContentPage from "../components/ContentPage.astro";
---

<BaseLayout
  title="Contact Us — AI Face Shape Analyzer"
  description="Get in touch with the AI Face Shape Analyzer team. Send feedback, feature ideas, privacy requests, or support questions by email."
  path="/contact"
  keywords="contact ai face shape analyzer, face shape analyzer support, face shape analyzer feedback"
>
  <ContentPage
    eyebrow="Contact"
    heading="Contact Us"
    lead="Questions, feedback, or a feature idea? We’d love to hear from you. The fastest way to reach us is by email."
  >
    <h2>Email us</h2>
    <ul>
      <li>
        <strong>General &amp; feedback:</strong>
        <a href="mailto:hello@aifaceshapeanalyzer.com">hello@aifaceshapeanalyzer.com</a>
      </li>
      <li>
        <strong>Privacy requests:</strong>
        <a href="mailto:privacy@aifaceshapeanalyzer.com">privacy@aifaceshapeanalyzer.com</a>
      </li>
    </ul>
    <p>
      We read every message and aim to reply within a few business days. For
      privacy questions, see our <a href="/privacy-policy">Privacy Policy</a>;
      for usage questions, our <a href="/terms-and-conditions">Terms &amp;
      Conditions</a>.
    </p>

    <h2>Send a message</h2>
    <p>
      Fill in the fields below and we’ll open a pre-filled email in your mail
      app — just hit send.
    </p>

    <form id="contact-form" class="contact-form" novalidate>
      <div class="field">
        <label for="cf-name">Name</label>
        <input id="cf-name" name="name" type="text" autocomplete="name" required />
      </div>
      <div class="field">
        <label for="cf-email">Your email</label>
        <input id="cf-email" name="email" type="email" autocomplete="email" required />
      </div>
      <div class="field">
        <label for="cf-message">Message</label>
        <textarea id="cf-message" name="message" rows="6" required></textarea>
      </div>
      <p id="cf-error" class="contact-error" role="alert" hidden></p>
      <button type="submit" class="btn-primary">Open email to send</button>
    </form>

    <p class="contact-fallback">
      Prefer to write directly? Email
      <a href="mailto:hello@aifaceshapeanalyzer.com">hello@aifaceshapeanalyzer.com</a>.
    </p>
  </ContentPage>
</BaseLayout>

<script is:inline>
  (() => {
    const form = document.getElementById("contact-form");
    if (!form) return;
    const err = document.getElementById("cf-error");
    const TO = "hello@aifaceshapeanalyzer.com";

    const showError = (msg) => {
      if (!err) return;
      err.textContent = msg;
      err.hidden = false;
    };

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      if (err) err.hidden = true;

      const name = form.elements["name"].value.trim();
      const email = form.elements["email"].value.trim();
      const message = form.elements["message"].value.trim();

      if (!name || !email || !message) {
        showError("Please fill in your name, email, and message.");
        return;
      }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showError("Please enter a valid email address.");
        return;
      }

      const subject = `Contact from ${name}`;
      const body = `${message}\n\n— ${name} (${email})`;
      const href =
        `mailto:${TO}?subject=${encodeURIComponent(subject)}` +
        `&body=${encodeURIComponent(body)}`;
      window.location.href = href;
    });
  })();
</script>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    max-width: 520px;
    margin: var(--spacing-lg) 0 var(--spacing-xl);
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xxs);
  }
  .field label {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-ink);
  }
  .field input,
  .field textarea {
    width: 100%;
    padding: var(--spacing-sm) var(--spacing-md);
    font: inherit;
    font-size: 15px;
    color: var(--color-ink);
    background-color: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .field textarea {
    resize: vertical;
    min-height: 120px;
  }
  .field input:focus-visible,
  .field textarea:focus-visible {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 25%, transparent);
  }
  .contact-error {
    margin: 0;
    color: var(--color-error);
    font-size: 14px;
    line-height: 20px;
  }
  .contact-form .btn-primary {
    align-self: flex-start;
  }
  .contact-fallback {
    font-size: 14px;
    color: var(--color-mute);
  }

  @media (max-width: 560px) {
    .contact-form .btn-primary {
      align-self: stretch;
      text-align: center;
    }
  }
</style>
