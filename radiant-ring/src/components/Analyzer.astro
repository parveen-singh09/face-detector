---
/**
 * Analyzer — the interactive core: upload OR camera, a live face-mesh overlay,
 * and a full probability breakdown across all six shapes.
 *
 * Rendering strategy: all static chrome is server-rendered (zero JS until the
 * user interacts). The client script statically imports only the tiny pure
 * modules (faceShape, rateLimit) and DYNAMICALLY imports the heavy MediaPipe
 * wrappers (faceLandmarker, meshOverlay) the first time a mode is activated, so
 * the ~15MB WASM+model never touches the homepage's critical path.
 *
 * i18n: all server-rendered strings come from the dictionary. Strings the client
 * script needs at runtime (status/error messages, dynamic labels, localized
 * shape names + descriptions) are serialized into a JSON island the script reads
 * on load — so the logic stays untouched and copy stays in the dictionary.
 */
import ShapeBar from "./ShapeBar.astro";
import { SHAPE_IDS, type ShapeId } from "../lib/faceShape";
import { DEFAULT_LOCALE, type Locale } from "../i18n/config";
import { useTranslations } from "../i18n/utils";

interface Props {
  lang?: Locale;
}
const { lang = DEFAULT_LOCALE } = Astro.props;
const t = useTranslations(lang);
const a = t.analyzer;

// Localized shape label list for the pre-rendered breakdown bars.
const SHAPES = SHAPE_IDS.map((id) => [id, t.shapeLabels[id]] as [ShapeId, string]);

// Strings the client script reads from the JSON island below.
const scriptI18n = {
  messages: a.msg,
  shapeLabels: t.shapeLabels,
  shapeDescriptions: t.shapeDescriptions,
};
---

<section id="analyzer" class="analyzer container-page" aria-labelledby="analyzer-heading">
  <div class="analyzer-head">
    <p class="eyebrow">{a.eyebrow}</p>
    <h2 id="analyzer-heading">{a.heading}</h2>
    <p class="analyzer-sub">{a.sub}</p>
  </div>

  <div class="card-lg analyzer-card">
    <!-- Mode tabs -->
    <div class="mode-tabs" role="tablist" aria-label={a.tablistAria}>
      <button
        id="tab-upload"
        class="mode-tab is-active"
        role="tab"
        aria-selected="true"
        aria-controls="panel-stage"
        data-mode="upload"
        type="button"
      >
        {a.tabUpload}
      </button>
      <button
        id="tab-camera"
        class="mode-tab"
        role="tab"
        aria-selected="false"
        aria-controls="panel-stage"
        data-mode="camera"
        type="button"
      >
        {a.tabCamera}
      </button>
    </div>

    <div class="analyzer-grid">
      <!-- Left column: stage + disclaimer -->
      <div class="panel-main">
        <!-- Stage: dropzone / image / video + overlay -->
      <div id="panel-stage" class="stage" role="tabpanel" aria-labelledby="tab-upload">
        <!-- Upload dropzone -->
        <div id="dropzone" class="dropzone" data-view="upload">
          <input
            id="file-input"
            class="visually-hidden"
            type="file"
            accept="image/jpeg,image/png,image/webp"
            aria-label={a.fileInputAria}
          />
          <label for="file-input" class="dropzone-label">
            <span class="dropzone-icon" aria-hidden="true">⊕</span>
            <span class="dropzone-title">{a.dropzoneTitle}</span>
            <span class="dropzone-hint">{a.dropzoneHint}</span>
          </label>
        </div>

        <!-- Media preview (image or video) with the mesh overlay canvas -->
        <div id="media-wrap" class="media-wrap" hidden>
          <img id="preview-img" class="media" alt={a.previewImgAlt} hidden />
          <video
            id="preview-video"
            class="media"
            playsinline
            muted
            hidden
            aria-label={a.cameraPreviewAria}></video>
          <canvas id="overlay" class="overlay" aria-hidden="true"></canvas>
        </div>

        <!-- Loading / model-init state -->
        <div id="stage-loading" class="stage-loading" hidden role="status">
          <span class="spinner" aria-hidden="true"></span>
          <span id="loading-text">{a.loadingModel}</span>
        </div>
      </div>

      <!-- Disclaimer sits directly under the stage -->
      <p class="result-disclaimer">
        <span class="result-disclaimer-icon" aria-hidden="true">ⓘ</span>
        <span>{a.resultDisclaimer}</span>
      </p>
      </div>

      <!-- Controls + results -->
      <div class="panel-side">
        <!-- Action row -->
        <div class="actions">
          <button id="btn-analyze" class="btn-primary" type="button" hidden>
            {a.btnAnalyze}
          </button>
          <button id="btn-capture" class="btn-primary" type="button" hidden>
            {a.btnCapture}
          </button>
          <button id="btn-reset" class="btn-secondary" type="button" hidden>
            {a.btnReset}
          </button>
        </div>

        <!-- Capture progress (camera mode): one segment per reading -->
        <div
          id="capture-progress"
          class="capture-progress"
          role="progressbar"
          aria-valuemin="0"
          aria-valuenow="0"
          hidden
        >
          <span id="capture-dots" class="capture-dots" aria-hidden="true"></span>
        </div>

        <!-- Inline messages (errors / rate limit) -->
        <p id="message" class="message" role="alert" hidden></p>

        <!-- Upload tips (shown only in upload mode) -->
        <ul id="upload-tips" class="cam-tips" aria-label={a.uploadTipsAria}>
          <li><span aria-hidden="true">📸</span> {a.uploadTips[0]}</li>
          <li><span aria-hidden="true">🖼️</span> {a.uploadTips[1]}</li>
          <li><span aria-hidden="true">💇</span> {a.uploadTips[2]}</li>
        </ul>

        <!-- Camera capture tips (shown only in camera mode) -->
        <ul id="cam-tips" class="cam-tips" hidden aria-label={a.camTipsAria}>
          <li><span aria-hidden="true">👓</span> {a.camTips[0]}</li>
          <li><span aria-hidden="true">🧑</span> {a.camTips[1]}</li>
          <li><span aria-hidden="true">🤚</span> {a.camTips[2]}</li>
        </ul>

        <!-- Results -->
        <div id="results" class="results" hidden aria-live="polite">
          <div class="result-headline">
            <span class="eyebrow">{a.resultEyebrow}</span>
            <div class="result-top-row">
              <h3 id="result-shape">—</h3>
              <span id="result-confidence" class="result-confidence">—</span>
            </div>
            <p id="result-desc" class="result-desc"></p>
            <p id="result-metrics" class="result-metrics" aria-hidden="true"></p>
          </div>

          <div class="breakdown">
            <p class="breakdown-title">{a.breakdownTitle}</p>
            <div class="breakdown-list" role="list">
              {SHAPES.map(([id, label]) => <ShapeBar id={id} label={label} />)}
            </div>
          </div>
        </div>

        <!-- Idle helper copy (before first result) -->
        <div id="idle-help" class="idle-help">
          <p class="idle-help-title">{a.idleTitle}</p>
          <ul>
            <li>{a.idleItems[0]}</li>
            <li>{a.idleItems[1]}</li>
            <li>{a.idleItems[2]}</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- i18n island: strings the client script reads at runtime. -->
  <script type="application/json" id="analyzer-i18n" set:html={JSON.stringify(scriptI18n)}></script>
</section>

<script>
  import {
    classifyFace,
    classifyFaceMulti,
    MEASURE_IDX,
    type ShapeResult,
    type ShapeId,
  } from "../lib/faceShape";
  import {
    checkRateLimit,
    recordAnalysis,
    formatRetryAfter,
  } from "../lib/rateLimit";

  // ── i18n strings (from the JSON island) ────────────────────────────────────
  type I18n = {
    messages: Record<string, string>;
    shapeLabels: Record<ShapeId, string>;
    shapeDescriptions: Record<ShapeId, string>;
  };
  const I: I18n = JSON.parse(
    document.getElementById("analyzer-i18n")?.textContent || "{}",
  );
  const M = I.messages;
  // Tiny placeholder interpolator: fill("{n}/{total}", {n:1,total:5}).
  const fill = (tpl: string, vars: Record<string, string | number>) =>
    tpl.replace(/\{(\w+)\}/g, (_, k) => String(vars[k] ?? ""));

  const MAX_BYTES = 10 * 1024 * 1024;
  // How many camera readings the user clicks to capture, then we average them
  // for a more stable, accurate result.
  const CAPTURE_FRAMES = 5;

  // ── Element refs ──────────────────────────────────────────────────────────
  const $ = <T extends HTMLElement>(id: string) =>
    document.getElementById(id) as T;

  const tabUpload = $("tab-upload") as HTMLButtonElement;
  const tabCamera = $("tab-camera") as HTMLButtonElement;
  const dropzone = $("dropzone");
  const fileInput = $("file-input") as HTMLInputElement;
  const mediaWrap = $("media-wrap");
  const previewImg = $("preview-img") as HTMLImageElement;
  const previewVideo = $("preview-video") as HTMLVideoElement;
  const overlay = $("overlay") as HTMLCanvasElement;
  const camTips = $("cam-tips");
  const uploadTips = $("upload-tips");
  const stageLoading = $("stage-loading");
  const loadingText = $("loading-text");
  const btnAnalyze = $("btn-analyze") as HTMLButtonElement;
  const btnCapture = $("btn-capture") as HTMLButtonElement;
  const btnReset = $("btn-reset") as HTMLButtonElement;
  const captureProgress = $("capture-progress");
  const captureDots = $("capture-dots");
  const message = $("message");
  const results = $("results");
  const idleHelp = $("idle-help");
  const resultShape = $("result-shape");
  const resultConfidence = $("result-confidence");
  const resultDesc = $("result-desc");
  const resultMetrics = $("result-metrics");

  // Lazily-loaded heavy modules (MediaPipe).
  type LandmarkerMod = typeof import("../lib/faceLandmarker");
  type OverlayMod = typeof import("../lib/meshOverlay");
  let landmarkerMod: LandmarkerMod | null = null;
  let overlayMod: OverlayMod | null = null;

  let mode: "upload" | "camera" = "upload";
  let stream: MediaStream | null = null;
  // Bumped on every stopCamera (and at the start of each startCamera) so a
  // startCamera whose async startup finishes AFTER the user switched away can
  // detect it's stale and bail instead of painting the camera over the stage.
  let camGen = 0;
  let rafId = 0;
  let lastLandmarks: any[] | null = null;
  let videoReady = false;
  // Readings collected one-per-click in camera mode; classified on the 5th.
  let captureFrames: any[][] = [];

  async function loadModules() {
    if (!landmarkerMod || !overlayMod) {
      showLoading(M.loadingModel);
      [landmarkerMod, overlayMod] = await Promise.all([
        import("../lib/faceLandmarker"),
        import("../lib/meshOverlay"),
      ]);
      hideLoading();
    }
    return { landmarkerMod: landmarkerMod!, overlayMod: overlayMod! };
  }

  // ── UI helpers ──────────────────────────────────────────────────────────
  function showLoading(text: string) {
    loadingText.textContent = text;
    stageLoading.hidden = false;
  }
  function hideLoading() {
    stageLoading.hidden = true;
  }
  function showMessage(text: string, kind: "error" | "info" = "error") {
    message.textContent = text;
    message.dataset.kind = kind;
    message.hidden = false;
  }
  function clearMessage() {
    message.hidden = true;
    message.textContent = "";
  }

  // Camera capture progress: one segment per reading, filled as they're taken.
  function renderCaptureProgress(filled: number, total: number) {
    captureProgress.setAttribute("aria-valuemax", String(total));
    captureProgress.setAttribute("aria-valuenow", String(filled));
    captureProgress.setAttribute(
      "aria-label",
      fill(M.captureReading, { n: Math.min(filled + 1, total), total }),
    );
    if (captureDots.childElementCount !== total) {
      captureDots.replaceChildren();
      for (let i = 0; i < total; i++) {
        const dot = document.createElement("span");
        dot.className = "capture-dot";
        captureDots.appendChild(dot);
      }
    }
    Array.from(captureDots.children).forEach((dot, i) =>
      (dot as HTMLElement).classList.toggle("is-filled", i < filled),
    );
  }
  function showCaptureProgress(filled: number, total: number) {
    renderCaptureProgress(filled, total);
    captureProgress.hidden = false;
  }
  function hideCaptureProgress() {
    captureProgress.hidden = true;
  }

  function setMode(next: "upload" | "camera") {
    if (next === mode) return;
    stopCamera();
    clearMessage();
    hideResults();
    mode = next;

    const onUpload = next === "upload";
    tabUpload.classList.toggle("is-active", onUpload);
    tabCamera.classList.toggle("is-active", !onUpload);
    tabUpload.setAttribute("aria-selected", String(onUpload));
    tabCamera.setAttribute("aria-selected", String(!onUpload));

    resetStage();
    if (next === "camera") startCamera();
  }

  function resetStage() {
    cancelAnimationFrame(rafId);
    lastLandmarks = null;
    videoReady = false;
    captureFrames = [];
    mediaWrap.hidden = true;
    previewImg.hidden = true;
    previewVideo.hidden = true;
    overlay.getContext("2d")?.clearRect(0, 0, overlay.width, overlay.height);
    btnAnalyze.hidden = true;
    btnCapture.hidden = true;
    btnReset.hidden = true;
    hideCaptureProgress();
    camTips.hidden = mode !== "camera";
    uploadTips.hidden = mode !== "upload";
    dropzone.hidden = mode !== "upload";
    if (previewImg.src) {
      URL.revokeObjectURL(previewImg.src);
      previewImg.removeAttribute("src");
    }
    // Clear the input value so re-selecting the SAME file still fires `change`.
    fileInput.value = "";
  }

  function hideResults() {
    results.hidden = true;
    idleHelp.hidden = false;
  }
  function showResults() {
    results.hidden = false;
    idleHelp.hidden = true;
  }

  // ── Rate limit gate ───────────────────────────────────────────────────────
  function gateByRateLimit(): boolean {
    const status = checkRateLimit();
    if (!status.allowed) {
      showMessage(
        fill(M.rateLimited, {
          retryAfter: formatRetryAfter(status.retryAfterMs),
        }),
      );
      return false;
    }
    return true;
  }

  // ── Upload flow ───────────────────────────────────────────────────────────
  function handleFile(file: File) {
    clearMessage();
    if (!["image/jpeg", "image/png", "image/webp"].includes(file.type)) {
      showMessage(M.fileType);
      return;
    }
    if (file.size > MAX_BYTES) {
      showMessage(M.fileTooLarge);
      return;
    }
    const url = URL.createObjectURL(file);
    previewImg.onload = () => {
      URL.revokeObjectURL(url);
      dropzone.hidden = true;
      mediaWrap.hidden = false;
      previewImg.hidden = false;
      btnAnalyze.hidden = false;
      btnReset.hidden = false;
    };
    previewImg.onerror = () => {
      URL.revokeObjectURL(url);
      showMessage(M.readError);
    };
    previewImg.src = url;
  }

  async function analyzeImage() {
    if (!gateByRateLimit()) return;
    btnAnalyze.disabled = true;
    try {
      const { landmarkerMod, overlayMod } = await loadModules();
      showLoading(M.analyzing);
      const res = await landmarkerMod.detectImage(previewImg);
      hideLoading();

      const faces = res.faceLandmarks;
      if (!faces || faces.length === 0) {
        showMessage(M.noFace);
        return;
      }
      const w = previewImg.naturalWidth;
      const h = previewImg.naturalHeight;
      overlayMod.syncCanvasSize(overlay, previewImg);
      overlayMod.drawMesh(overlay, faces[0], {});
      overlayMod.drawMeasurePoints(overlay, faces[0], MEASURE_IDX);
      recordAnalysis();
      renderResult(classifyFace(faces[0], w, h));
    } catch (err) {
      hideLoading();
      console.error(err);
      showMessage(M.analyzeError);
    } finally {
      btnAnalyze.disabled = false;
    }
  }

  // ── Camera flow ───────────────────────────────────────────────────────────
  async function startCamera() {
    clearMessage();
    if (!navigator.mediaDevices?.getUserMedia) {
      showMessage(M.noCameraSupport);
      return;
    }
    // Tag this startup. If the user switches away (stopCamera bumps camGen)
    // while we're awaiting below, this run is stale and must not touch the UI.
    const myGen = ++camGen;
    const stale = () => myGen !== camGen || mode !== "camera";
    try {
      const { overlayMod } = await loadModules();
      if (stale()) return;
      // Warm the VIDEO-mode landmarker before the loop starts.
      await landmarkerMod!.preloadLandmarker("VIDEO");
      if (stale()) return;

      const s = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: "user", width: { ideal: 1280 }, height: { ideal: 720 } },
        audio: false,
      });
      // If we switched away while waiting on the permission/stream, discard it.
      if (stale()) {
        s.getTracks().forEach((t) => t.stop());
        return;
      }
      stream = s;
      previewVideo.srcObject = stream;
      await previewVideo.play();
      if (stale()) return;

      dropzone.hidden = true;
      mediaWrap.hidden = false;
      previewVideo.hidden = false;
      btnCapture.hidden = false;
      btnCapture.textContent = fill(M.captureReading, { n: 1, total: CAPTURE_FRAMES });
      btnReset.hidden = false;
      showCaptureProgress(0, CAPTURE_FRAMES);
      videoReady = true;
      captureFrames = [];
      overlayMod.syncCanvasSize(overlay, previewVideo);
      runVideoLoop();
    } catch (err) {
      if (stale()) return;
      console.error(err);
      showMessage(M.cameraError);
    }
  }

  function runVideoLoop() {
    const loop = async () => {
      if (!videoReady || !stream) return;
      if (previewVideo.readyState >= 2 && landmarkerMod && overlayMod) {
        try {
          const res = landmarkerMod.detectVideoFrame(
            previewVideo,
            performance.now(),
          );
          // detectForVideo is synchronous in tasks-vision, but guard anyway.
          const result = (res as any)?.faceLandmarks ? (res as any) : await res;
          const faces = result.faceLandmarks;
          overlayMod.syncCanvasSize(overlay, previewVideo);
          if (faces && faces.length > 0) {
            lastLandmarks = faces[0];
            overlayMod.drawMesh(overlay, faces[0], { mirrored: true });
          } else {
            lastLandmarks = null;
            overlayMod.clearOverlay(overlay);
          }
        } catch (e) {
          /* transient frame error — keep looping */
        }
      }
      rafId = requestAnimationFrame(loop);
    };
    rafId = requestAnimationFrame(loop);
  }

  // One click = one reading. The live preview loop keeps running and tracks the
  // latest landmarks; each click snapshots them and fills a progress dot. On the
  // CAPTURE_FRAMES-th click we average the readings and show the result.
  function captureAndAnalyze() {
    if (!gateByRateLimit()) return;
    if (!lastLandmarks || !landmarkerMod || !overlayMod) {
      showMessage(M.noFaceYet);
      return;
    }
    clearMessage();

    // Snapshot the current reading.
    captureFrames.push(lastLandmarks);
    renderCaptureProgress(captureFrames.length, CAPTURE_FRAMES);

    const remaining = CAPTURE_FRAMES - captureFrames.length;
    if (remaining > 0) {
      btnCapture.textContent = fill(M.captureReading, {
        n: captureFrames.length + 1,
        total: CAPTURE_FRAMES,
      });
      return;
    }

    // Final reading collected — stop the live loop and classify.
    const w = previewVideo.videoWidth;
    const h = previewVideo.videoHeight;
    videoReady = false;
    cancelAnimationFrame(rafId);

    try {
      recordAnalysis();
      renderResult(classifyFaceMulti(captureFrames, w, h));
      // Freeze on the captured result.
      btnCapture.hidden = true;
      hideCaptureProgress();
    } catch (err) {
      console.error(err);
      showMessage(M.captureError);
      captureFrames = [];
      btnCapture.textContent = fill(M.captureReading, { n: 1, total: CAPTURE_FRAMES });
      renderCaptureProgress(0, CAPTURE_FRAMES);
      videoReady = true;
      runVideoLoop();
    }
  }

  function stopCamera() {
    videoReady = false;
    camGen++; // invalidate any in-flight startCamera startup
    cancelAnimationFrame(rafId);
    if (stream) {
      stream.getTracks().forEach((t) => t.stop());
      stream = null;
    }
    previewVideo.srcObject = null;
  }

  // ── Result rendering ──────────────────────────────────────────────────────
  function renderResult(result: ShapeResult) {
    showResults();
    clearMessage();

    // Calibration aid: log the raw measured ratios + the resulting distribution.
    // These are what the classifier actually saw — use them to tune
    // SHAPE_PROFILES in faceShape.ts. Remove once the classifier is dialed in.
    const f = result.features;
    console.log("[faceShape] measured features", {
      lengthToWidth: +f.lengthToWidth.toFixed(3),
      foreheadToCheek: +f.foreheadToCheek.toFixed(3),
      jawToCheek: +f.jawToCheek.toFixed(3),
      chinAngle: +f.chinAngle.toFixed(1),
      jawAngularity: +f.jawAngularity.toFixed(3),
    });
    console.table(
      result.ranked.map((s) => ({ shape: s.id, probability: s.probability })),
    );

    // On-screen calibration readout (so the measured ratios are visible without
    // opening devtools). Remove once SHAPE_PROFILES are dialed in.
    resultMetrics.textContent =
      `L/W ${f.lengthToWidth.toFixed(2)} · ` +
      `fore/cheek ${f.foreheadToCheek.toFixed(2)} · ` +
      `jaw/cheek ${f.jawToCheek.toFixed(2)} · ` +
      `chin ${f.chinAngle.toFixed(0)}° · ` +
      `jaw-angle ${f.jawAngularity.toFixed(2)}`;

    const topId = result.top.id as ShapeId;
    const runnerUpId = result.runnerUp.id as ShapeId;
    resultShape.textContent = I.shapeLabels[topId];
    resultConfidence.textContent = fill(M.confidence, { pct: result.confidence });

    if (result.isBlend) {
      resultDesc.textContent = fill(M.blendDesc, {
        top: I.shapeLabels[topId],
        runnerUp: I.shapeLabels[runnerUpId],
        desc: I.shapeDescriptions[topId],
      });
    } else {
      resultDesc.textContent = I.shapeDescriptions[topId];
    }

    // Reorder + fill the pre-rendered bars by probability.
    const list = document.querySelector(".breakdown-list") as HTMLElement;
    result.ranked.forEach((score, i) => {
      const row = list.querySelector(
        `[data-shape="${score.id}"]`,
      ) as HTMLElement;
      if (!row) return;
      row.style.order = String(i);
      row.classList.toggle("is-top", i === 0);
      (row.querySelector("[data-fill]") as HTMLElement).style.setProperty(
        "--pct",
        String(score.probability / 100),
      );
      (row.querySelector("[data-pct]") as HTMLElement).textContent =
        `${score.probability}%`;
    });
    list.style.display = "flex";
    list.style.flexDirection = "column";

    results.scrollIntoView({ behavior: "smooth", block: "nearest" });
  }

  function reset() {
    if (mode === "camera") {
      hideResults();
      clearMessage();
      resetStage();
      startCamera();
    } else {
      hideResults();
      clearMessage();
      resetStage();
    }
  }

  // ── Wiring ────────────────────────────────────────────────────────────────
  tabUpload.addEventListener("click", () => setMode("upload"));
  tabCamera.addEventListener("click", () => setMode("camera"));

  fileInput.addEventListener("change", () => {
    const file = fileInput.files?.[0];
    if (file) handleFile(file);
  });

  // Drag & drop
  ["dragover", "dragenter"].forEach((evt) =>
    dropzone.addEventListener(evt, (e) => {
      e.preventDefault();
      dropzone.classList.add("is-dragover");
    }),
  );
  ["dragleave", "drop"].forEach((evt) =>
    dropzone.addEventListener(evt, (e) => {
      e.preventDefault();
      dropzone.classList.remove("is-dragover");
    }),
  );
  dropzone.addEventListener("drop", (e) => {
    const file = (e as DragEvent).dataTransfer?.files?.[0];
    if (file) handleFile(file);
  });

  btnAnalyze.addEventListener("click", analyzeImage);
  btnCapture.addEventListener("click", captureAndAnalyze);
  btnReset.addEventListener("click", reset);

  // Clean up the camera if the user navigates away.
  window.addEventListener("pagehide", stopCamera);

  // Start in upload mode with the dropzone visible.
  resetStage();
</script>

<style>
  .analyzer {
    scroll-margin-top: 80px;
    padding-block: var(--spacing-5xl);
  }
  .analyzer-head {
    max-width: 640px;
    margin-bottom: var(--spacing-xl);
  }
  .analyzer-head h2 {
    margin: var(--spacing-xs) 0;
    font-size: clamp(26px, 5vw, 32px);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.03em;
  }
  .analyzer-sub {
    color: var(--color-body);
    font-size: 16px;
    line-height: 24px;
