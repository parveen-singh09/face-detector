---
import { DEFAULT_LOCALE, type Locale } from "../i18n/config";
import { delocalizePath, useTranslations } from "../i18n/utils";

interface Props {
  eyebrow: string;
  heading: string;
  lead?: string;
  updated?: string;
  lang?: Locale;
  mtNotice?: boolean;
}

const {
  eyebrow,
  heading,
  lead,
  updated,
  lang = DEFAULT_LOCALE,
  mtNotice = false,
} = Astro.props;

const t = useTranslations(lang);
const showNotice = mtNotice && lang !== DEFAULT_LOCALE;
const enHref = delocalizePath(Astro.url.pathname) || "/";
const noticeHtml = showNotice
  ? t.mtNotice.replace("{enHref}", enHref)
  : "";
---

<section class="page-hero">
  <div class="container-page page-hero-inner">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{heading}</h1>
    {lead && <p class="page-lead">{lead}</p>}
    {updated && <p class="page-updated">{t.contentPage.lastUpdated} {updated}</p>}
  </div>
</section>

<section class="section">
  <div class="container-page legal-prose">
    {showNotice && <p class="mt-notice" set:html={noticeHtml} />}
    <slot />
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  .page-hero-inner {
    padding-block: var(--spacing-5xl) var(--spacing-3xl);
    max-width: 760px;
  }
  .page-hero h1 {
    margin: var(--spacing-xs) 0 0;
    font-size: clamp(32px, 6vw, 48px);
    font-weight: 600;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    text-wrap: balance;
  }
  .page-lead {
    margin: var(--spacing-md) 0 0;
    max-width: 60ch;
    font-size: 18px;
    line-height: 28px;
    color: var(--color-body);
    text-wrap: pretty;
  }
  .page-updated {
    margin: var(--spacing-md) 0 0;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-mute);
  }

  .legal-prose {
    max-width: 760px;
  }
  .mt-notice {
    margin: 0 0 var(--spacing-lg);
    padding: var(--spacing-sm) var(--spacing-md);
    background-color: var(--color-canvas-soft);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
    color: var(--color-mute);
    font-size: 13px;
    line-height: 19px;
    text-wrap: pretty;
  }
  .mt-notice :global(a) {
    color: var(--color-link);
    text-decoration: underline;
  }
  .legal-prose :global(p) {
    margin: 0 0 var(--spacing-md);
    color: var(--color-body);
    font-size: 16px;
    line-height: 26px;
    text-wrap: pretty;
  }
  .legal-prose :global(h2) {
    margin: var(--spacing-2xl) 0 var(--spacing-sm);
    font-size: clamp(22px, 4vw, 26px);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }
  .legal-prose :global(h2:first-child) {
    margin-top: 0;
  }
  .legal-prose :global(h3) {
    margin: var(--spacing-xl) 0 var(--spacing-xs);
    font-size: 19px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }
  .legal-prose :global(ul),
  .legal-prose :global(ol) {
    margin: 0 0 var(--spacing-md);
    padding-left: var(--spacing-lg);
    color: var(--color-body);
    font-size: 16px;
    line-height: 26px;
  }
  .legal-prose :global(li) {
    margin: 0 0 var(--spacing-xs);
    text-wrap: pretty;
  }
  .legal-prose :global(li::marker) {
    color: var(--color-mute);
  }
  .legal-prose :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }
  .legal-prose :global(a) {
    color: var(--color-link);
    text-decoration: underline;
  }
  .legal-prose :global(hr) {
    margin: var(--spacing-2xl) 0;
    border: 0;
    border-top: 1px solid var(--color-hairline);
  }

  @media (max-width: 560px) {
    .page-hero-inner {
      padding-block: var(--spacing-4xl) var(--spacing-2xl);
    }
  }
</style>
