---
/**
 * ErrorState — the shared shell for error pages (404, 500, …). A centered hero
 * on the signature mesh gradient: a big gradient status code, a heading, a short
 * explanation, and recovery CTAs. Kept generic so each error page is just a thin
 * wrapper that passes copy in.
 */
import MeshGradient from "./MeshGradient.astro";

interface Props {
  /** HTTP status code shown large, e.g. "404". */
  code: string;
  /** Short headline, e.g. "Page not found". */
  title: string;
  /** One- or two-sentence explanation. */
  message: string;
}

const { code, title, message } = Astro.props;
---

<section class="error">
  <MeshGradient class="error-mesh" />
  <div class="container-page error-inner">
    <p class="error-code" aria-hidden="true">{code}</p>
    <p class="eyebrow error-eyebrow">Error {code}</p>
    <h1>{title}</h1>
    <p class="error-sub">{message}</p>
    <div class="error-cta">
      <a href="/" class="btn-primary">Back to home</a>
      <a href="/#analyzer" class="btn-secondary">Analyze my face</a>
    </div>
  </div>
</section>

<style>
  .error {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    /* Fill the viewport minus the sticky nav so the page never looks empty. */
    min-height: calc(100vh - 64px);
    padding-block: var(--spacing-5xl);
  }

  .error-mesh {
    /* Calmer than the homepage hero — this is an interruption, not a welcome. */
    opacity: 0.5;
  }

  .error-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .error-code {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: clamp(96px, 22vw, 200px);
    line-height: 1;
    letter-spacing: -0.04em;
    margin-bottom: var(--spacing-sm);
    /* Brand gradient lettering (develop → preview stops). */
    background-image: linear-gradient(
      135deg,
      var(--color-grad-develop-start),
      var(--color-grad-preview-end)
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .error-eyebrow {
    margin-bottom: var(--spacing-md);
  }

  h1 {
    font-size: clamp(28px, 5vw, 40px);
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin-bottom: var(--spacing-md);
  }

  .error-sub {
    max-width: 48ch;
    font-size: 18px;
    line-height: 28px;
    color: var(--color-body);
    text-wrap: balance;
    margin-bottom: var(--spacing-xl);
  }

  .error-cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-sm);
  }

  @media (max-width: 560px) {
    .error-cta {
      width: 100%;
    }
    .error-cta :global(.btn-primary),
    .error-cta :global(.btn-secondary) {
      flex: 1;
      min-width: 0;
    }
  }
</style>
