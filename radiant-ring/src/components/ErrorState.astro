---
import { DEFAULT_LOCALE, type Locale } from "../i18n/config";
import { localizePath, useTranslations } from "../i18n/utils";

interface Props {
  code: string;
  title: string;
  message: string;
  lang?: Locale;
}

const { code, title, message, lang = DEFAULT_LOCALE } = Astro.props;
const t = useTranslations(lang);
const L = (p: string) => localizePath(p, lang);
---

<section class="error">
  <div class="container-page error-inner">
    <p class="error-code" aria-hidden="true">{code}</p>
    <p class="eyebrow error-eyebrow">{t.error.eyebrow.replace("{code}", code)}</p>
    <h1>{title}</h1>
    <p class="error-sub">{message}</p>
    <div class="error-cta">
      <a href={L("/")} class="btn-primary">{t.error.ctaHome}</a>
      <a href={L("/#analyzer")} class="btn-secondary">{t.error.ctaAnalyze}</a>
    </div>
  </div>
</section>

<style>
  .error {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    min-height: calc(100vh - 64px);
    padding-block: var(--spacing-5xl);
  }

  .error-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .error-code {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: clamp(96px, 22vw, 200px);
    line-height: 1;
    letter-spacing: -0.04em;
    margin-bottom: var(--spacing-sm);
    background-image: linear-gradient(
      135deg,
      var(--color-grad-develop-start),
      var(--color-grad-preview-end)
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .error-eyebrow {
    margin-bottom: var(--spacing-md);
  }

  h1 {
    font-size: clamp(28px, 5vw, 40px);
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin-bottom: var(--spacing-md);
  }

  .error-sub {
    max-width: 48ch;
    font-size: 18px;
    line-height: 28px;
    color: var(--color-body);
    text-wrap: balance;
    margin-bottom: var(--spacing-xl);
  }

  .error-cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-sm);
  }

  @media (max-width: 560px) {
    .error-cta {
      width: 100%;
    }
    .error-cta :global(.btn-primary),
    .error-cta :global(.btn-secondary) {
      flex: 1;
      min-width: 0;
    }
  }
</style>
