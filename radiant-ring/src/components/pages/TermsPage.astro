---
/**
 * TermsPage — the Terms & Conditions body, parameterized by locale. Rendered by
 * `/terms-and-conditions` (en) and `/[lang]/terms-and-conditions`. Prose + the
 * "updated" date come from the dictionary; an MT notice shows on translations.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContentPage from "../ContentPage.astro";
import { DEFAULT_LOCALE, type Locale } from "../../i18n/config";
import { useTranslations } from "../../i18n/utils";

interface Props {
  lang?: Locale;
}
const { lang = DEFAULT_LOCALE } = Astro.props;
const t = useTranslations(lang);
const p = t.pages.terms;
---

<BaseLayout
  lang={lang}
  title={p.title}
  description={p.description}
  path="/terms-and-conditions"
  keywords={p.keywords}
>
  <ContentPage
    lang={lang}
    mtNotice={true}
    eyebrow={p.eyebrow}
    heading={p.heading}
    lead={p.lead}
    updated={p.updated}
  >
    <Fragment set:html={p.html} />
  </ContentPage>
</BaseLayout>
