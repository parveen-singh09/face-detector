---
import {
  LOCALES,
  LOCALE_LABELS,
  LOCALE_FLAG,
  type Locale,
} from "../i18n/config";
import { getLangFromUrl, localizePath, useTranslations } from "../i18n/utils";

interface Props {
  class?: string;
}
const { class: className } = Astro.props;

const current: Locale = getLangFromUrl(Astro.url);
const options = LOCALES.map((loc) => ({
  value: localizePath(Astro.url.pathname, loc),
  label: LOCALE_LABELS[loc],
  flag: LOCALE_FLAG[loc],
  selected: loc === current,
}));
const currentLabel = LOCALE_LABELS[current];
const currentFlag = LOCALE_FLAG[current];
const label = useTranslations(current).nav.langLabel;

const uid = "ls-" + Math.random().toString(36).slice(2, 9);
const listId = `${uid}-list`;
---

<div class:list={["lang-switcher", className]} data-lang-switcher>
  <button
    type="button"
    class="lang-trigger"
    id={`${uid}-btn`}
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-controls={listId}
    aria-label={label}
  >
    <svg
      class="lang-icon"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="9"></circle>
      <path d="M3 12h18M12 3c2.5 2.5 2.5 15.5 0 18M12 3c-2.5 2.5-2.5 15.5 0 18"></path>
    </svg>
    <img
      class="lang-flag-current"
      src={`/flags/${currentFlag}.svg`}
      width="20"
      height="20"
      alt=""
      aria-hidden="true"
      decoding="async"
    />
    <span class="lang-current">{currentLabel}</span>
    <svg
      class="lang-chevron"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M6 9l6 6 6-6"></path>
    </svg>
  </button>

  <ul
    class="lang-menu"
    id={listId}
    role="listbox"
    tabindex="-1"
    aria-label={label}
    hidden
  >
    {
      options.map((o, i) => (
        <li
          class:list={["lang-option", { "is-selected": o.selected }]}
          id={`${uid}-opt-${i}`}
          role="option"
          aria-selected={o.selected ? "true" : "false"}
          data-value={o.value}
        >
          {
            o.selected ? (
              <svg
                class="lang-check"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M5 12.5l4.5 4.5L19 7" />
              </svg>
            ) : (
              <span class="lang-check-spacer" aria-hidden="true" />
            )
          }
          <img
            class="lang-flag"
            src={`/flags/${o.flag}.svg`}
            width="20"
            height="20"
            alt=""
            aria-hidden="true"
            loading="lazy"
            decoding="async"
          />
          <span class="lang-option-label">{o.label}</span>
        </li>
      ))
    }
  </ul>
</div>

<script>
  function initLangSwitcher(root: HTMLElement) {
    if (root.dataset.lsReady) return;
    root.dataset.lsReady = "1";

    const trigger = root.querySelector<HTMLButtonElement>(".lang-trigger");
    const menu = root.querySelector<HTMLUListElement>(".lang-menu");
    const options = Array.from(
      root.querySelectorAll<HTMLLIElement>(".lang-option"),
    );
    if (!trigger || !menu || options.length === 0) return;

    let open = false;
    let activeIndex = Math.max(
      0,
      options.findIndex((o) => o.getAttribute("aria-selected") === "true"),
    );

    const setActive = (i: number) => {
      activeIndex = (i + options.length) % options.length;
      options.forEach((o, idx) =>
        o.classList.toggle("is-active", idx === activeIndex),
      );
      const act = options[activeIndex];
      menu.setAttribute("aria-activedescendant", act.id);
      act.scrollIntoView({ block: "nearest" });
    };

    const openMenu = () => {
      if (open) return;
      open = true;
      menu.hidden = false;
      trigger.setAttribute("aria-expanded", "true");
      setActive(activeIndex);
      menu.focus();
    };

    const closeMenu = (focusTrigger: boolean) => {
      if (!open) return;
      open = false;
      menu.hidden = true;
      trigger.setAttribute("aria-expanded", "false");
      menu.removeAttribute("aria-activedescendant");
      options.forEach((o) => o.classList.remove("is-active"));
      if (focusTrigger) trigger.focus();
    };

    const navigate = (i: number) => {
      const href = options[i]?.dataset.value;
      if (href) window.location.href = href;
    };

    trigger.addEventListener("click", () =>
      open ? closeMenu(true) : openMenu(),
    );
    trigger.addEventListener("keydown", (e) => {
      if (["ArrowDown", "ArrowUp", "Enter", " "].includes(e.key)) {
        e.preventDefault();
        openMenu();
      }
    });

    menu.addEventListener("keydown", (e) => {
      switch (e.key) {
        case "ArrowDown":
          e.preventDefault();
          setActive(activeIndex + 1);
          break;
        case "ArrowUp":
          e.preventDefault();
          setActive(activeIndex - 1);
          break;
        case "Home":
          e.preventDefault();
          setActive(0);
          break;
        case "End":
          e.preventDefault();
          setActive(options.length - 1);
          break;
        case "Enter":
        case " ":
          e.preventDefault();
          navigate(activeIndex);
          break;
        case "Escape":
          e.preventDefault();
          closeMenu(true);
          break;
        case "Tab":
          closeMenu(false);
          break;
      }
    });

    options.forEach((o, i) => {
      o.addEventListener("click", () => navigate(i));
      o.addEventListener("mousemove", () => {
        if (activeIndex !== i) setActive(i);
      });
    });

    document.addEventListener("click", (e) => {
      if (open && !root.contains(e.target as Node)) closeMenu(false);
    });
  }

  document
    .querySelectorAll<HTMLElement>("[data-lang-switcher]")
    .forEach(initLangSwitcher);
</script>

<style>
  .lang-switcher {
    position: relative;
    display: inline-flex;
  }

  .lang-trigger {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xxs);
    height: 36px;
    padding-inline: var(--spacing-xs);
    color: var(--color-body);
    background-color: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-full);
    font: inherit;
    font-size: 14px;
    line-height: 20px;
    cursor: pointer;
    touch-action: manipulation;
    transition: color 0.15s ease, background-color 0.15s ease,
      border-color 0.15s ease;
  }
  .lang-trigger:hover {
    color: var(--color-ink);
    background-color: var(--color-canvas-soft-2);
  }
  .lang-icon {
    width: 16px;
    height: 16px;
    flex: none;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.6;
  }
  .lang-current {
    max-width: 11ch;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .lang-flag-current {
    display: none;
    width: 20px;
    height: 20px;
    flex: none;
    border-radius: var(--radius-full);
    object-fit: cover;
    box-shadow: 0 0 0 1px var(--color-hairline);
  }
  .lang-chevron {
    width: 14px;
    height: 14px;
    flex: none;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: transform 0.18s ease;
  }
  .lang-trigger[aria-expanded="true"] .lang-chevron {
    transform: rotate(180deg);
  }

  .lang-menu {
    position: absolute;
    inset-inline-end: 0;
    top: calc(100% + var(--spacing-xxs));
    z-index: 60;
    min-width: 100%;
    width: max-content;
    max-width: 260px;
    max-height: min(60vh, 360px);
    overflow-y: auto;
    overscroll-behavior: contain;
    scrollbar-width: thin;
    scrollbar-color: var(--color-hairline) transparent;
    margin: 0;
    padding: var(--spacing-xxs);
    list-style: none;
    background-color: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    box-shadow:
      0 0 0 1px var(--shadow-ring, #00000014) inset,
      0 4px 8px -2px var(--shadow-soft, #00000014),
      0 12px 24px -8px var(--shadow-soft, #00000014);
    animation: lang-menu-in 0.14s ease;
  }
  .lang-menu:focus-visible {
    outline: none;
  }
  .lang-menu::-webkit-scrollbar {
    width: 8px;
  }
  .lang-menu::-webkit-scrollbar-track {
    background: transparent;
  }
  .lang-menu::-webkit-scrollbar-thumb {
    background-color: var(--color-hairline);
    border-radius: var(--radius-full);
    border: 2px solid transparent;
    background-clip: padding-box;
  }
  .lang-menu::-webkit-scrollbar-thumb:hover {
    background-color: var(--color-mute);
    background-clip: padding-box;
  }
  @keyframes lang-menu-in {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .lang-menu {
      animation: none;
    }
  }

  .lang-option {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    min-height: 36px;
    padding-block: var(--spacing-xxs);
    padding-inline: var(--spacing-xs);
    color: var(--color-body);
    font-size: 14px;
    line-height: 20px;
    border-radius: var(--radius-sm);
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
  }
  .lang-option:hover,
  .lang-option.is-active {
    color: var(--color-ink);
    background-color: var(--color-canvas-soft-2);
  }
  .lang-option.is-selected {
    color: var(--color-ink);
    font-weight: 500;
  }
  .lang-check {
    flex: none;
  }
  .lang-check-spacer {
    width: 16px;
    height: 16px;
    flex: none;
  }
  .lang-flag {
    width: 20px;
    height: 20px;
    flex: none;
    border-radius: var(--radius-full);
    object-fit: cover;
    box-shadow: 0 0 0 1px var(--color-hairline);
  }
  .lang-option-label {
    flex: 1;
  }

  .lang-switcher.is-block {
    display: flex;
    width: 100%;
  }
  .lang-switcher.is-block .lang-trigger {
    width: 100%;
    height: 44px;
    justify-content: flex-start;
  }
  .lang-switcher.is-block .lang-current {
    flex: 1;
    max-width: none;
    text-align: start;
  }
  .lang-switcher.is-block .lang-menu {
    inset-inline: 0;
    width: auto;
    max-width: none;
  }

  @media (max-width: 760px) {
    .lang-switcher.nav-lang .lang-trigger {
      gap: 0;
      width: 36px;
      padding-inline: 0;
      justify-content: center;
    }
    .lang-switcher.nav-lang .lang-icon,
    .lang-switcher.nav-lang .lang-current,
    .lang-switcher.nav-lang .lang-chevron {
      display: none;
    }
    .lang-switcher.nav-lang .lang-flag-current {
      display: block;
    }
  }
</style>
