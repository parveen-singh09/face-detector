---
/**
 * Footer — bottom band (DESIGN.md footer: canvas bg, body text, mono eyebrows).
 * Marketing footer with brand line + lightweight link columns. Content pages
 * (per-shape, FAQ, blog) are deferred, so links point at on-page anchors for now.
 */
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container-page footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="AI Face Shape Analyzer — home">
        <img
          class="footer-logo-mark"
          src="/favicon-96x96.png"
          width="20"
          height="20"
          alt=""
          aria-hidden="true"
        />
        <span>Face Shape Analyzer</span>
      </a>
      <p class="footer-tagline">
        Find your face shape in seconds — free and accurate, with a full
        breakdown across all six shapes.
      </p>
    </div>

    <nav class="footer-col" aria-label="Product">
      <p class="eyebrow">Product</p>
      <a href="/#analyzer">Analyze my face</a>
      <a href="/#how-it-works">How it works</a>
      <a href="/#shapes">Face shapes</a>
    </nav>

    <nav class="footer-col" aria-label="About">
      <p class="eyebrow">About</p>
      <a href="/#about">About the tool</a>
      <a href="/#faq">FAQ</a>
    </nav>

    <nav class="footer-col" aria-label="Company">
      <p class="eyebrow">Company</p>
      <a href="/about-us">About us</a>
      <a href="/contact">Contact us</a>
      <a href="/privacy-policy">Privacy policy</a>
      <a href="/terms-and-conditions">Terms &amp; conditions</a>
    </nav>
  </div>

  <div class="container-page footer-base">
    <p>© {year} aifaceshapeanalyzer.com</p>
    <p class="footer-mono">Six shapes · 478-point face mesh</p>
  </div>

  <div class="container-page footer-disclaimer">
    <p>
      Disclaimer: face shape is a subjective label, not an exact measurement.
      Results are an estimate generated from your photo and can vary with angle,
      lighting, expression, hair, glasses, and camera lens. Many faces are a
      blend of two shapes — use this as a guide for styling, not as definitive
      or professional advice.
    </p>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
    padding-block: var(--spacing-4xl) var(--spacing-xl);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--spacing-2xl);
  }
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    color: var(--color-ink);
    text-decoration: none;
    font-weight: 600;
    font-size: 15px;
    letter-spacing: -0.02em;
  }
  .footer-logo-mark {
    width: 20px;
    height: 20px;
    border-radius: var(--radius-sm);
    object-fit: cover;
  }
  .footer-tagline {
    margin-top: var(--spacing-sm);
    max-width: 34ch;
    color: var(--color-body);
    font-size: 14px;
    line-height: 20px;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }
  .footer-col .eyebrow {
    margin-bottom: var(--spacing-xxs);
  }
  .footer-col a {
    color: var(--color-body);
    text-decoration: none;
    font-size: 14px;
    line-height: 20px;
    transition: color 0.15s ease;
  }
  .footer-col a:hover {
    color: var(--color-ink);
  }
  .footer-base {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    margin-top: var(--spacing-3xl);
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--color-hairline);
    color: var(--color-mute);
    font-size: 13px;
  }
  .footer-mono {
    font-family: var(--font-mono);
    font-size: 12px;
  }
  .footer-disclaimer {
    margin-top: var(--spacing-md);
  }
  .footer-disclaimer p {
    max-width: 80ch;
    color: var(--color-mute);
    font-size: 12px;
    line-height: 18px;
    text-wrap: pretty;
  }

  @media (max-width: 760px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 480px) {
    .footer-base {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--spacing-xs);
    }
  }
</style>
