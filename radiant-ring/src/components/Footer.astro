---
import { DEFAULT_LOCALE, type Locale } from "../i18n/config";
import { localizePath, useTranslations } from "../i18n/utils";

interface Props {
  lang?: Locale;
}
const { lang = DEFAULT_LOCALE } = Astro.props;
const t = useTranslations(lang);
const L = (p: string) => localizePath(p, lang);
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container-page footer-inner">
    <div class="footer-brand">
      <a href={L("/")} class="footer-logo" aria-label={t.footer.logoAria}>
        <img
          class="footer-logo-mark"
          src="/favicon-96x96.png"
          width="20"
          height="20"
          alt=""
          aria-hidden="true"
        />
        <span>{t.footer.brandName}</span>
      </a>
      <p class="footer-tagline">{t.footer.tagline}</p>
    </div>

    <nav class="footer-col" aria-label={t.footer.productEyebrow}>
      <p class="eyebrow">{t.footer.productEyebrow}</p>
      <a href={L("/#analyzer")}>{t.footer.productLinks.analyze}</a>
      <a href={L("/#how-it-works")}>{t.footer.productLinks.how}</a>
      <a href={L("/#shapes")}>{t.footer.productLinks.shapes}</a>
    </nav>

    <nav class="footer-col" aria-label={t.footer.aboutEyebrow}>
      <p class="eyebrow">{t.footer.aboutEyebrow}</p>
      <a href={L("/#about")}>{t.footer.aboutLinks.aboutTool}</a>
      <a href={L("/#faq")}>{t.footer.aboutLinks.faq}</a>
    </nav>

    <nav class="footer-col" aria-label={t.footer.companyEyebrow}>
      <p class="eyebrow">{t.footer.companyEyebrow}</p>
      <a href={L("/about-us")}>{t.footer.companyLinks.about}</a>
      <a href={L("/contact")}>{t.footer.companyLinks.contact}</a>
      <a href={L("/privacy-policy")}>{t.footer.companyLinks.privacy}</a>
      <a href={L("/terms-and-conditions")}>{t.footer.companyLinks.terms}</a>
    </nav>
  </div>

  <div class="container-page footer-base">
    <p>© {year} aifaceshapeanalyzer.com</p>
    <p class="footer-mono">{t.footer.mono}</p>
  </div>

  <div class="container-page footer-disclaimer">
    <p>{t.footer.disclaimer}</p>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
    padding-block: var(--spacing-4xl) var(--spacing-xl);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--spacing-2xl);
  }
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    color: var(--color-ink);
    text-decoration: none;
    font-weight: 600;
    font-size: 15px;
    letter-spacing: -0.02em;
  }
  .footer-logo-mark {
    width: 20px;
    height: 20px;
    border-radius: var(--radius-sm);
    object-fit: cover;
  }
  .footer-tagline {
    margin-top: var(--spacing-sm);
    max-width: 34ch;
    color: var(--color-body);
    font-size: 14px;
    line-height: 20px;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }
  .footer-col .eyebrow {
    margin-bottom: var(--spacing-xxs);
  }
  .footer-col a {
    color: var(--color-body);
    text-decoration: none;
    font-size: 14px;
    line-height: 20px;
    transition: color 0.15s ease;
  }
  .footer-col a:hover {
    color: var(--color-ink);
  }
  .footer-base {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    margin-top: var(--spacing-3xl);
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--color-hairline);
    color: var(--color-mute);
    font-size: 13px;
  }
  .footer-mono {
    font-family: var(--font-mono);
    font-size: 12px;
  }
  .footer-disclaimer {
    margin-top: var(--spacing-md);
  }
  .footer-disclaimer p {
    max-width: 80ch;
    color: var(--color-mute);
    font-size: 12px;
    line-height: 18px;
    text-wrap: pretty;
  }

  @media (max-width: 760px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 480px) {
    .footer-base {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--spacing-xs);
    }
  }
</style>
